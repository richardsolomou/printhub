# Host paths for the two container mounts. Everything else — storage,
# board visibility, telemetry — is configured in the app under Settings.
DATA_HOST_DIR=./printhub-data
PRINTS_HOST_DIR=./prints
# Put this on a different disk, dataset, or remote backup mount from DATA_HOST_DIR.
BACKUPS_HOST_DIR=./backups
# Optional: 32 random bytes encoded as 64 hex characters or base64.
RECOVERY_ENCRYPTION_KEY=
